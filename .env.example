# Copy to `.env` and fill in. Loaded automatically from the package directory via
# ``python-dotenv`` when ``vix_dashboard.config`` is imported.

# --- Required for live Tastytrade API (OAuth refresh flow) ---
TT_SECRET=
TT_REFRESH=

# --- Optional API client overrides ---
# TT_API_VERSION=20251101
# TT_USER_AGENT=vix-dashboard / 1.0.0

# --- Optional offline / fallback CSV paths (panel: date,vix,vvix,spx,f0,f1) ---
# VIX_PANEL_CSV=
# VVIX_CSV=
